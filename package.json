{
  "name": "ecom",
  "version": "1.0.0",
  "description": "Virtual Vault - E-commerce REST API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "server": "nodemon server.js",
    "client": "npm start --prefix ./client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "sonarqube": "sonar-scanner",
    "nft:soak": "k6 run --summary-export=tests/soak/soak-summary.json --out json=tests/soak/soak-results.ndjson tests/soak/soak.js",
    "nft:soak:quick": "k6 run -e RAMP_UP=10s -e SOAK_DURATION=1m -e RAMP_DOWN=10s --summary-export=tests/soak/quick/soak-summary.json --out json=tests/soak/quick/soak-results.ndjson tests/soak/soak.js",
    "nft:spike": "node tests/spike/orchestrate.js",
    "nft:spike:cleanup": "node tests/spike/cleanup.js",
    "test": "npm run test:backend & npm run test:integration & npm run test:e2e & npm run test:ui & npm run test:a11y",
    "test:frontend": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.frontend.config.js",
    "test:backend": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.backend.config.js",
    "test:ui": "npx playwright test client/tests/ui",
    "test:a11y": "npx playwright test tests/a11y",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.integration.config.js --runInBand",
    "test:e2e": "npx playwright test e2e",
    "test:ai": "npm test -- --coverage > jest-output.txt 2>&1 && node scripts/aiTestAgent.js"
  },
  "mongodbMemoryServer": {
    "downloadDir": ".cache/mongodb-binaries"
  },
  "keywords": [],
  "author": "RP",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "braintree": "^3.22.0",
    "colors": "^1.4.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "date-fns": "^3.3.1",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-formidable": "^1.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.21.0",
    "mongoose": "^8.1.2",
    "morgan": "^1.10.0",
    "nodemon": "^3.0.3",
    "react-icons": "^5.0.1",
    "slugify": "^1.6.6",
    "supertest": "^7.2.2"
  },
  "devDependencies": {
    "@babel/core": "^7.24.5",
    "@babel/preset-env": "^7.24.5",
    "@babel/preset-react": "^7.24.1",
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.12.12",
    "babel-jest": "^29.7.0",
    "cross-env": "^10.1.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "mongodb-memory-server": "^11.0.1",
    "sonarqube-scanner": "^4.3.5",
    "supertest": "^7.2.2"
  }
}