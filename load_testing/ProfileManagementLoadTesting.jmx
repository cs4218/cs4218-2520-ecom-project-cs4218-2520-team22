        <CSVDataSet guiclass="TestBeanGUI" testclass="CSVDataSet" testname="Login User Credentials">
          <stringProp name="filename">C:/Users/USER/Documents/cs4218-2520-ecom-project-cs4218-2520-team22/load_testing/testUsers.csv</stringProp>
          <stringProp name="fileEncoding">UTF-8</stringProp>
